# Required for ServerChan WeChat push
SERVERCHAN_SENDKEY=put_your_sendkey_here

# Optional: Enterprise WeChat group robot webhook
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxx

# Optional: comma-separated keywords. Leave empty to collect all papers.
KEYWORDS=single-cell,spatial transcriptomics,CRISPR,CAR-T,organoid,machine learning,protein design,immunotherapy

# Optional: OpenAI-compatible LLM summarization. Leave empty for the first run.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
